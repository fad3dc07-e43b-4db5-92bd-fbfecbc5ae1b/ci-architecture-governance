          "recordId": "7632c7e4-368e-46b9-8150-e11087b7cbb2",
          "field": "name",
          "value": "Indefinite and constant pace of sponsors, developers and users",
          "message": "El nombre debe ser claro, legible y comenzar con mayúscula."
